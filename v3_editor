import os
import re
import shutil
import tkinter as tk
from tkinter import filedialog, messagebox, ttk


class Victoria3SaveEditor:

    def __init__(self, root):
        self.root = root
        self.root.title("Victoria 3 Pop Save Editor")
        self.root.geometry("620x600")
        self.root.resizable(False, False)

        # State Variables
        self.file_path = tk.StringVar()
        self.state_id = tk.StringVar()

        # Job modification dictionary tracking individual StringVars
        self.job_list = [
            "laborers",
            "machinists",
            "engineers",
            "farmers",
            "clergymen",
            "clerks",
            "officers",
            "bureaucrats",
            "aristocrats",
            "capitalists",
            "shopkeepers",
            "academics",
            "servicemen",
            "peasants",
            "slaves",
        ]
        self.job_inputs = {job: tk.StringVar(value="0") for job in self.job_list}

        # Religion list for dropdown selection
        self.religion_list = [
            "catholic",
            "protestant",
            "orthodox",
            "oriental_orthodox",
            "sunni",
            "shiite",
            "ibadi",
            "jewish",
            "gelugpa",
            "mahayana",
            "theravada",
            "hindu",
            "sikh",
            "confucian",
            "shinto",
            "animist",
            "athiest",
            "mormon",
        ]

        # Dynamic Row Lists
        self.culture_rows = []
        self.religion_rows = []

        self.create_widgets()

    def create_widgets(self):
        # 1. File Selection Frame
        file_frame = ttk.LabelFrame(self.root, text=" 1. Select Save File ", padding=10)
        file_frame.pack(fill="x", padx=15, pady=10)

        ttk.Entry(
            file_frame, textvariable=self.file_path, width=53, state="readonly"
        ).pack(side="left", padx=5)
        ttk.Button(file_frame, text="Browse...", command=self.browse_file).pack(
            side="left", padx=5
        )

        # 2. Filter Frame (State ID)
        filter_frame = ttk.LabelFrame(
            self.root, text=" 2. Target Location ", padding=10
        )
        filter_frame.pack(fill="x", padx=15, pady=5)

        ttk.Label(filter_frame, text="State ID (Location):").pack(
            side="left", padx=5
        )
        ttk.Entry(filter_frame, textvariable=self.state_id, width=15).pack(
            side="left", padx=5
        )

        # 3. Modifications Notebook (Tabs)
        notebook = ttk.Notebook(self.root)
        notebook.pack(fill="both", expand=True, padx=15, pady=10)

        # --- Tab 1: Specific Workforce Changes ---
        tab_job = ttk.Frame(notebook, padding=10)
        notebook.add(tab_job, text="Modify Workforces")

        ttk.Label(
            tab_job, text="Enter TOTAL workforce to add (divided evenly among state's pops):"
        ).pack(anchor="w", pady=(0, 5))

        canvas_frame = ttk.Frame(tab_job)
        canvas_frame.pack(fill="both", expand=True)

        canvas = tk.Canvas(
            canvas_frame, borderwidth=0, highlightthickness=0, height=150
        )
        scrollbar = ttk.Scrollbar(
            canvas_frame, orient="vertical", command=canvas.yview
        )
        scrollable_frame = ttk.Frame(canvas)

        scrollable_frame.bind(
            "<Configure>",
            lambda e: canvas.configure(scrollregion=canvas.bbox("all")),
        )
        canvas.create_window((0, 0), window=scrollable_frame, anchor="nw")
        canvas.configure(yscrollcommand=scrollbar.set)

        canvas.pack(side="left", fill="both", expand=True)
        scrollbar.pack(side="right", fill="y")

        for index, job in enumerate(self.job_list):
            row = index // 2
            col_base = (index % 2) * 2

            lbl = ttk.Label(scrollable_frame, text=f"{job}:", width=12, anchor="e")
            lbl.grid(row=row, column=col_base, sticky="w", padx=(10, 2), pady=4)

            ent = ttk.Entry(
                scrollable_frame, textvariable=self.job_inputs[job], width=8
            )
            ent.grid(row=row, column=col_base + 1, sticky="w", padx=(0, 15), pady=4)

        # --- Tab 2: Dynamic Cultures ---
        self.tab_culture = ttk.Frame(notebook, padding=10)
        notebook.add(self.tab_culture, text="Change Culture")

        self.btn_init_culture = ttk.Button(
            self.tab_culture, text="Swap Culture", command=self.add_culture_row
        )
        self.btn_init_culture.pack(anchor="center", expand=True, pady=20)

        self.culture_container = ttk.Frame(self.tab_culture)
        self.btn_add_more_culture = ttk.Button(
            self.tab_culture, text="Add Another", command=self.add_culture_row
        )

        # --- Tab 3: Dynamic Religions ---
        self.tab_religion = ttk.Frame(notebook, padding=10)
        notebook.add(self.tab_religion, text="Change Religion")

        self.btn_init_religion = ttk.Button(
            self.tab_religion, text="Swap Religion", command=self.add_religion_row
        )
        self.btn_init_religion.pack(anchor="center", expand=True, pady=20)

        self.religion_container = ttk.Frame(self.tab_religion)
        self.btn_add_more_religion = ttk.Button(
            self.tab_religion, text="Add Another", command=self.add_religion_row
        )

        # 4. Master Process Button
        btn_process = ttk.Button(
            self.root,
            text="Apply Changes Directly to File",
            command=self.process_file,
        )
        btn_process.pack(pady=15)

    def browse_file(self):
        filename = filedialog.askopenfilename(
            filetypes=[("Victoria 3 Save", "*.v3"), ("Text Files", "*.txt")]
        )
        if filename:
            self.file_path.set(filename)

    def add_culture_row(self):
        if not self.culture_container.winfo_manager():
            self.btn_init_culture.pack_forget()
            self.culture_container.pack(fill="both", expand=True, pady=5)
            self.btn_add_more_culture.pack(anchor="w", padx=5, pady=5)

        row_frame = ttk.Frame(self.culture_container)
        row_frame.pack(fill="x", pady=2)

        tgt_var = tk.StringVar()
        new_var = tk.StringVar()

        lbl1 = ttk.Label(row_frame, text="Target ID:")
        lbl1.pack(side="left", padx=2)
        ent1 = ttk.Entry(row_frame, textvariable=tgt_var, width=12)
        ent1.pack(side="left", padx=5)

        lbl2 = ttk.Label(row_frame, text="New ID:")
        lbl2.pack(side="left", padx=2)
        ent2 = ttk.Entry(row_frame, textvariable=new_var, width=12)
        ent2.pack(side="left", padx=5)

        row_dict = {"frame": row_frame, "tgt_var": tgt_var, "new_var": new_var}

        btn_del = ttk.Button(
            row_frame,
            text="❌",
            width=3,
            command=lambda: self.remove_culture_row(row_dict),
        )
        btn_del.pack(side="left", padx=10)

        self.culture_rows.append(row_dict)

    def remove_culture_row(self, row_dict):
        row_dict["frame"].destroy()
        self.culture_rows.remove(row_dict)

        if not self.culture_rows:
            self.culture_container.pack_forget()
            self.btn_add_more_culture.pack_forget()
            self.btn_init_culture.pack(anchor="center", expand=True, pady=20)

    def add_religion_row(self):
        if not self.religion_container.winfo_manager():
            self.btn_init_religion.pack_forget()
            self.religion_container.pack(fill="both", expand=True, pady=5)
            self.btn_add_more_religion.pack(anchor="w", padx=5, pady=5)

        row_frame = ttk.Frame(self.religion_container)
        row_frame.pack(fill="x", pady=2)

        tgt_var = tk.StringVar()
        new_var = tk.StringVar()

        lbl1 = ttk.Label(row_frame, text="Target:")
        lbl1.pack(side="left", padx=2)
        cb1 = ttk.Combobox(
            row_frame,
            textvariable=tgt_var,
            values=self.religion_list,
            width=16,
            state="readonly",
        )
        cb1.pack(side="left", padx=5)

        lbl2 = ttk.Label(row_frame, text="New:")
        lbl2.pack(side="left", padx=2)
        cb2 = ttk.Combobox(
            row_frame,
            textvariable=new_var,
            values=self.religion_list,
            width=16,
            state="readonly",
        )
        cb2.pack(side="left", padx=5)

        row_dict = {"frame": row_frame, "tgt_var": tgt_var, "new_var": new_var}

        btn_del = ttk.Button(
            row_frame,
            text="❌",
            width=3,
            command=lambda: self.remove_religion_row(row_dict),
        )
        btn_del.pack(side="left", padx=10)

        self.religion_rows.append(row_dict)

    def remove_religion_row(self, row_dict):
        row_dict["frame"].destroy()
        self.religion_rows.remove(row_dict)

        if not self.religion_rows:
            self.religion_container.pack_forget()
            self.btn_add_more_religion.pack_forget()
            self.btn_init_religion.pack(anchor="center", expand=True, pady=20)

    def process_file(self):
        input_path = self.file_path.get()
        state_id = self.state_id.get().strip()

        if not input_path or not os.path.exists(input_path):
            messagebox.showerror("Error", "Please select a valid save file.")
            return
        if not state_id:
            messagebox.showerror(
                "Error", "Please specify a Target Location (State ID)."
            )
            return

        # Gather requested total workforce pools
        requested_totals = {}
        for job, var in self.job_inputs.items():
            val_str = var.get().strip()
            if val_str:
                try:
                    amt = int(val_str)
                    if amt != 0:
                        requested_totals[job] = amt
                except ValueError:
                    messagebox.showerror(
                        "Error", f"Value for '{job}' must be an integer."
                    )
                    return

        # Gather multiple culture maps
        culture_map = {}
        for r in self.culture_rows:
            t = r["tgt_var"].get().strip()
            n = r["new_var"].get().strip()
            if t and n:
                culture_map[t] = n

        # Gather multiple religion maps
        religion_map = {}
        for r in self.religion_rows:
            t = r["tgt_var"].get().strip()
            n = r["new_var"].get().strip()
            if t and n:
                religion_map[t] = n

        try:
            # PASS 1: Count target pop chunks matching criteria
            pop_counts = self.count_matching_pops(input_path, state_id, list(requested_totals.keys()))

            # Mathematically compute the dynamic splits per block
            job_changes = {}
            for job, total_pool in requested_totals.items():
                count = pop_counts.get(job, 0)
                if count > 0:
                    # Using integer division to avoid float corruption in save structure
                    job_changes[job] = total_pool // count
                else:
                    # If user asked to add to a job type that doesn't exist in that state
                    job_changes[job] = 0

            # PASS 2: Stream edit with specific calculated block modifications
            self.stream_edit_save(
                input_path, state_id, job_changes, culture_map, religion_map
            )
            messagebox.showinfo("Success", "File modified successfully!")
        except Exception as e:
            messagebox.showerror("Error", f"An error occurred: {str(e)}")

    def count_matching_pops(self, in_file, target_state, target_jobs):
        """Pass 1: Fast stream to count pop segments matching state & job constraints."""
        pop_counts = {job: 0 for job in target_jobs}
        if not target_jobs:
            return pop_counts

        pop_start_re = re.compile(r"^\s*\d+=\s*\{")
        in_pop_block = False
        bracket_depth = 0
        pop_lines = []

        with open(in_file, "rb") as f_in:
            for raw_line in f_in:
                line = raw_line.decode("utf-8", errors="ignore")

                if not in_pop_block:
                    if pop_start_re.match(line):
                        in_pop_block = True
                        bracket_depth = 1
                        pop_lines = [line]
                else:
                    pop_lines.append(line)
                    bracket_depth += line.count("{")
                    bracket_depth -= line.count("}")

                    if bracket_depth == 0:
                        in_pop_block = False
                        block_text = "".join(pop_lines)
                        pop_lines = []

                        # Validate it's a real pop with a workforce parameter
                        if "workforce=" in block_text and "type=" in block_text:
                            loc_match = re.search(r"^\s*location=(\d+)", block_text, re.MULTILINE)
                            if loc_match and loc_match.group(1) == target_state:
                                type_match = re.search(r"^\s*type=(\w+)", block_text, re.MULTILINE)
                                if type_match:
                                    pop_job = type_match.group(1)
                                    if pop_job in pop_counts:
                                        pop_counts[pop_job] += 1
        return pop_counts

    def stream_edit_save(
        self, in_file, target_state, job_changes, culture_map, religion_map
    ):
        """Pass 2: Safely apply changes via binary swap logic."""
        pop_start_re = re.compile(r"^\s*\d+=\s*\{")

        in_pop_block = False
        bracket_depth = 0
        pop_lines = []

        temp_file = in_file + ".tmp"

        with open(in_file, "rb") as f_in, open(temp_file, "wb") as f_out:
            for raw_line in f_in:
                line = raw_line.decode("utf-8", errors="ignore")

                if not in_pop_block:
                    if pop_start_re.match(line):
                        in_pop_block = True
                        bracket_depth = 1
                        pop_lines = [line]
                    else:
                        f_out.write(raw_line)
                else:
                    pop_lines.append(line)
                    bracket_depth += line.count("{")
                    bracket_depth -= line.count("}")

                    if bracket_depth == 0:
                        in_pop_block = False
                        modified_block = self.modify_pop_block(
                            pop_lines,
                            target_state,
                            job_changes,
                            culture_map,
                            religion_map,
                        )
                        for mod_line in modified_block:
                            f_out.write(mod_line.encode("utf-8"))
                        pop_lines = []

        shutil.move(temp_file, in_file)

    def modify_pop_block(
        self, lines, target_state, job_changes, culture_map, religion_map
    ):
        block_text = "".join(lines)

        if "workforce=" not in block_text or "type=" not in block_text:
            return lines

        loc_match = re.search(r"^\s*location=(\d+)", block_text, re.MULTILINE)
        if not loc_match or loc_match.group(1) != target_state:
            return lines

        type_match = re.search(r"^\s*type=(\w+)", block_text, re.MULTILINE)
        pop_job = type_match.group(1) if type_match else None

        new_lines = []
        for line in lines:
            stripped = line.strip()

            # 1. Process Calculated Workforce distribution splits
            if stripped.startswith("workforce=") and job_changes and pop_job:
                if pop_job in job_changes and job_changes[pop_job] != 0:
                    try:
                        current_wf = int(stripped.split("=")[1])
                        indent = line[: line.find("workforce=")]
                        line = f"{indent}workforce={current_wf + job_changes[pop_job]}\n"
                    except ValueError:
                        pass

            # 2. Process Multi-Culture modifications
            elif stripped.startswith("culture=") and culture_map:
                current_cult = stripped.split("=")[1].strip()
                if current_cult in culture_map:
                    indent = line[: line.find("culture=")]
                    line = f"{indent}culture={culture_map[current_cult]}\n"

            # 3. Process Multi-Religion modifications
            elif stripped.startswith("religion=") and religion_map:
                current_rel = stripped.split("=")[1].strip()
                if current_rel in religion_map:
                    indent = line[: line.find("religion=")]
                    line = f"{indent}religion={religion_map[current_rel]}\n"

            new_lines.append(line)

        return new_lines


if __name__ == "__main__":
    root = tk.Tk()
    app = Victoria3SaveEditor(root)
    root.mainloop()
