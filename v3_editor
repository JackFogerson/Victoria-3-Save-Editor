import os
import re
import shutil
import tkinter as tk
from tkinter import filedialog, messagebox, ttk


class Victoria3SaveEditor:

    def __init__(self, root):
        self.root = root
        self.root.title("Victoria 3 Pop Save Editor")
        self.root.geometry("580x550")
        self.root.resizable(False, False)

        # State Variables
        self.file_path = tk.StringVar()
        self.state_id = tk.StringVar()

        # Job modification dictionary tracking individual StringVars
        self.job_list = [
            "laborers",
            "machinists",
            "engineers",
            "farmers",
            "clergymen",
            "clerks",
            "officers",
            "bureaucrats",
            "aristocrats",
            "capitalists",
            "shopkeepers",
            "academics",
            "servicemen",
            "peasants",
            "slaves",
        ]
        self.job_inputs = {job: tk.StringVar(value="0") for job in self.job_list}

        # Culture modification
        self.target_culture = tk.StringVar()
        self.new_culture = tk.StringVar()

        # Religion modification
        self.target_religion = tk.StringVar()
        self.new_religion = tk.StringVar()
        self.religion_list = [
            "catholic",
            "protestant",
            "orthodox",
            "oriental_orthodox",
            "sunni",
            "shiite",
            "ibadi",
            "jewish",
            "gelugpa",
            "mahayana",
            "theravada",
            "hindu",
            "sikh",
            "confucian",
            "shinto",
            "animist",
            "athiest",
            "mormon",
        ]

        self.create_widgets()

    def create_widgets(self):
        # File Selection Frame
        file_frame = ttk.LabelFrame(self.root, text=" 1. Select Save File ", padding=10)
        file_frame.pack(fill="x", padx=15, pady=10)

        ttk.Entry(
            file_frame, textvariable=self.file_path, width=48, state="readonly"
        ).pack(side="left", padx=5)
        ttk.Button(file_frame, text="Browse...", command=self.browse_file).pack(
            side="left", padx=5
        )

        # Filter Frame (State ID)
        filter_frame = ttk.LabelFrame(
            self.root, text=" 2. Target Location ", padding=10
        )
        filter_frame.pack(fill="x", padx=15, pady=5)

        ttk.Label(filter_frame, text="State ID (Location):").pack(
            side="left", padx=5
        )
        ttk.Entry(filter_frame, textvariable=self.state_id, width=15).pack(
            side="left", padx=5
        )

        # Modifications Notebook (Tabs)
        notebook = ttk.Notebook(self.root)
        notebook.pack(fill="both", expand=True, padx=15, pady=10)

        # Tab 1: Specific Workforce Changes
        tab_job = ttk.Frame(notebook, padding=10)
        notebook.add(tab_job, text="Modify Workforces")

        ttk.Label(
            tab_job, text="Enter change amount for each job type (0 to ignore):"
        ).pack(anchor="w", pady=(0, 5))

        # Scrollable Frame for job entries
        canvas_frame = ttk.Frame(tab_job)
        canvas_frame.pack(fill="both", expand=True)

        canvas = tk.Canvas(
            canvas_frame, borderwidth=0, highlightthickness=0, height=150
        )
        scrollbar = ttk.Scrollbar(
            canvas_frame, orient="vertical", command=canvas.yview
        )
        scrollable_frame = ttk.Frame(canvas)

        scrollable_frame.bind(
            "<Configure>",
            lambda e: canvas.configure(scrollregion=canvas.bbox("all")),
        )
        canvas.create_window((0, 0), window=scrollable_frame, anchor="nw")
        canvas.configure(yscrollcommand=scrollbar.set)

        canvas.pack(side="left", fill="both", expand=True)
        scrollbar.pack(side="right", fill="y")

        # Grid system for specific job inputs (2 columns of label + entry pairs)
        for index, job in enumerate(self.job_list):
            row = index // 2
            col_base = (index % 2) * 2

            lbl = ttk.Label(scrollable_frame, text=f"{job}:", width=12, anchor="e")
            lbl.grid(row=row, column=col_base, sticky="w", padx=(10, 2), pady=4)

            ent = ttk.Entry(
                scrollable_frame, textvariable=self.job_inputs[job], width=8
            )
            ent.grid(row=row, column=col_base + 1, sticky="w", padx=(0, 15), pady=4)

        # Tab 2: Culture
        tab_culture = ttk.Frame(notebook, padding=10)
        notebook.add(tab_culture, text="Change Culture")

        ttk.Label(tab_culture, text="Target Culture ID:").grid(
            row=0, column=0, sticky="w", pady=5
        )
        ttk.Entry(tab_culture, textvariable=self.target_culture, width=15).grid(
            row=0, column=1, sticky="w", pady=5, padx=5
        )
        ttk.Label(tab_culture, text="New Culture ID:").grid(
            row=1, column=0, sticky="w", pady=5
        )
        ttk.Entry(tab_culture, textvariable=self.new_culture, width=15).grid(
            row=1, column=1, sticky="w", pady=5, padx=5
        )

        # Tab 3: Religion (Using Combobox Dropdowns)
        tab_religion = ttk.Frame(notebook, padding=10)
        notebook.add(tab_religion, text="Change Religion")

        ttk.Label(tab_religion, text="Target Religion:").grid(
            row=0, column=0, sticky="w", pady=5
        )
        tgt_rel_cb = ttk.Combobox(
            tab_religion,
            textvariable=self.target_religion,
            values=self.religion_list,
            width=22,
        )
        tgt_rel_cb.grid(row=0, column=1, sticky="w", pady=5, padx=5)

        ttk.Label(tab_religion, text="New Religion:").grid(
            row=1, column=0, sticky="w", pady=5
        )
        new_rel_cb = ttk.Combobox(
            tab_religion,
            textvariable=self.new_religion,
            values=self.religion_list,
            width=22,
        )
        new_rel_cb.grid(row=1, column=1, sticky="w", pady=5, padx=5)

        # Process Button (Direct Apply)
        btn_process = ttk.Button(
            self.root,
            text="Apply Changes Directly to File",
            command=self.process_file,
        )
        btn_process.pack(pady=15)

    def browse_file(self):
        filename = filedialog.askopenfilename(
            filetypes=[("Victoria 3 Save", "*.v3"), ("Text Files", "*.txt")]
        )
        if filename:
            self.file_path.set(filename)

    def process_file(self):
        input_path = self.file_path.get()
        state_id = self.state_id.get().strip()

        if not input_path or not os.path.exists(input_path):
            messagebox.showerror("Error", "Please select a valid save file.")
            return
        if not state_id:
            messagebox.showerror(
                "Error", "Please specify a Target Location (State ID)."
            )
            return

        # Parse specific workforce adjustment amounts
        job_changes = {}
        for job, var in self.job_inputs.items():
            val_str = var.get().strip()
            if val_str:
                try:
                    amt = int(val_str)
                    if amt != 0:
                        job_changes[job] = amt
                except ValueError:
                    messagebox.showerror(
                        "Error", f"Workforce value for '{job}' must be an integer."
                    )
                    return

        tgt_cult = self.target_culture.get().strip()
        new_cult = self.new_culture.get().strip()
        tgt_rel = self.target_religion.get().strip()
        new_rel = self.new_religion.get().strip()

        try:
            # Process directly using binary streaming swap logic
            self.stream_edit_save(
                input_path,
                state_id,
                job_changes,
                tgt_cult,
                new_cult,
                tgt_rel,
                new_rel,
            )
            messagebox.showinfo("Success", "File modified successfully!")
        except Exception as e:
            messagebox.showerror("Error", f"An error occurred: {str(e)}")

    def stream_edit_save(
        self,
        in_file,
        target_state,
        job_changes,
        t_cult,
        n_cult,
        t_rel,
        n_rel,
    ):
        pop_start_re = re.compile(r"^\s*\d+=\s*\{")

        in_pop_block = False
        bracket_depth = 0
        pop_lines = []

        temp_file = in_file + ".tmp"

        with open(in_file, "rb") as f_in, open(temp_file, "wb") as f_out:
            for raw_line in f_in:
                line = raw_line.decode("utf-8", errors="ignore")

                if not in_pop_block:
                    if pop_start_re.match(line):
                        in_pop_block = True
                        bracket_depth = 1
                        pop_lines = [line]
                    else:
                        f_out.write(raw_line)
                else:
                    pop_lines.append(line)
                    bracket_depth += line.count("{")
                    bracket_depth -= line.count("}")

                    if bracket_depth == 0:
                        in_pop_block = False
                        modified_block = self.modify_pop_block(
                            pop_lines,
                            target_state,
                            job_changes,
                            t_cult,
                            n_cult,
                            t_rel,
                            n_rel,
                        )
                        for mod_line in modified_block:
                            f_out.write(mod_line.encode("utf-8"))
                        pop_lines = []

        shutil.move(temp_file, in_file)

    def modify_pop_block(
        self,
        lines,
        target_state,
        job_changes,
        t_cult,
        n_cult,
        t_rel,
        n_rel,
    ):
        block_text = "".join(lines)

        if "workforce=" not in block_text:
            return lines

        loc_match = re.search(r"^\s*location=(\d+)", block_text, re.MULTILINE)
        if not loc_match or loc_match.group(1) != target_state:
            return lines

        new_lines = []
        for line in lines:
            stripped = line.strip()

            # Modify specific workforce configuration based on job_changes map
            if stripped.startswith("workforce=") and job_changes:
                type_match = re.search(
                    r"^\s*type=(\w+)", block_text, re.MULTILINE
                )
                if type_match:
                    pop_job = type_match.group(1)
                    if pop_job in job_changes:
                        try:
                            current_wf = int(stripped.split("=")[1])
                            indent = line[: line.find("workforce=")]
                            line = f"{indent}workforce={current_wf + job_changes[pop_job]}\n"
                        except ValueError:
                            pass

            # Modify Culture
            elif (
                stripped.startswith("culture=")
                and t_cult
                and n_cult
                and stripped.split("=")[1].strip() == t_cult
            ):
                indent = line[: line.find("culture=")]
                line = f"{indent}culture={n_cult}\n"

            # Modify Religion
            elif (
                stripped.startswith("religion=")
                and t_rel
                and n_rel
                and stripped.split("=")[1].strip() == t_rel
            ):
                indent = line[: line.find("religion=")]
                line = f"{indent}religion={n_rel}\n"

            new_lines.append(line)

        return new_lines


if __name__ == "__main__":
    root = tk.Tk()
    app = Victoria3SaveEditor(root)
    root.mainloop()
